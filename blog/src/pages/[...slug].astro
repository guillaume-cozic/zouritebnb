---
import { getCollection } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { counterpart, articleHref, homeHref, type Lang } from '../lib/i18n';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    // FR entries -> `<slug>`, EN entries -> `en/<slug>` (slug already carries the prefix)
    params: { slug: entry.slug },
    props: { entry, all: articles },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await entry.render();

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const lang = entry.data.lang;
const otherLang: Lang = lang === 'en' ? 'fr' : 'en';
const other = counterpart(entry, all);
const langSwitch = {
  href: other ? articleHref(baseUrl, other) : homeHref(baseUrl, otherLang),
  lang: otherLang,
};
---

<ArticleLayout entry={entry} langSwitch={langSwitch}>
  <Content />
</ArticleLayout>
