---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Le blog des activités, balades et sorties à Rodrigues.' } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const logoHref = `${baseUrl}logo.png`;
const faviconHref = `${baseUrl}favicon.ico`;
const frontUrl = import.meta.env.PUBLIC_FRONT_URL ?? '/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href={faviconHref} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 flex flex-col">
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <div class="flex items-center gap-6">
          <a href={frontUrl} class="flex items-center" aria-label="ZouriteBnb">
            <img
              src={logoHref}
              alt="ZouriteBnb"
              class="h-14 w-auto object-contain"
              loading="eager"
            />
          </a>
          <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
            <a href={baseUrl} class="hover:text-blue-600 transition-colors">
              Carnet de Rodrigues
            </a>
          </nav>
        </div>

        <div class="flex items-center gap-4">
          <a
            href={frontUrl}
            class="inline-flex items-center justify-center text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 h-10 rounded-xl px-5 transition-all hover:shadow-md hover:shadow-blue-200"
          >
            Réserver un hébergement
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-gray-900 text-gray-400">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
              </div>
              <span class="text-lg font-bold text-white">BnB</span>
            </div>
            <p class="text-sm leading-relaxed">
              Hébergement chez l'habitant à Rodrigues, et tout ce qu'il faut savoir
              pour profiter de votre séjour sur l'île.
            </p>
          </div>
          <div>
            <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Navigation</h4>
            <ul class="space-y-2.5 text-sm">
              <li>
                <a href={frontUrl} class="hover:text-white transition-colors">Hébergements</a>
              </li>
              <li>
                <a href={baseUrl} class="hover:text-white transition-colors">Carnet de Rodrigues</a>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contact</h4>
            <ul class="space-y-2.5 text-sm">
              <li>contact@bnb.com</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 py-6 text-center text-sm text-gray-500">
          &copy; {new Date().getFullYear()} ZouriteBnb. Tous droits réservés.
        </div>
      </div>
    </footer>
  </body>
</html>
