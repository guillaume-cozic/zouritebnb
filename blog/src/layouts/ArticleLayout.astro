---
import BaseLayout from './BaseLayout.astro';
import WhereToStay from '../components/WhereToStay.astro';
import type { CollectionEntry } from 'astro:content';
import { bareSlug, homeHref, type Lang } from '../lib/i18n';

interface Props {
  entry: CollectionEntry<'articles'>;
  langSwitch?: { href: string; lang: Lang } | null;
}

const { entry, langSwitch = null } = Astro.props;
const { data } = entry;
const lang = data.lang;

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const blogHome = homeHref(baseUrl, lang);
const cover = data.cover ?? `https://picsum.photos/seed/${bareSlug(entry)}/1600/900`;
const backLabel = lang === 'en' ? 'All articles' : 'Tous les articles';

const categoryLabels: Record<string, string> = {
  fr: {
    'reserves-et-parcs': 'Réserves & parcs',
    'points-de-vue': 'Points de vue',
    'randonnees': 'Randonnées',
    'sorties-en-mer': 'Sorties en mer',
    'sites-naturels': 'Sites naturels',
    'patrimoine': 'Patrimoine',
    'itineraires': 'Itinéraires',
  },
  en: {
    'reserves-et-parcs': 'Reserves & parks',
    'points-de-vue': 'Viewpoints',
    'randonnees': 'Hikes',
    'sorties-en-mer': 'Sea trips',
    'sites-naturels': 'Natural sites',
    'patrimoine': 'Heritage',
    'itineraires': 'Itineraries',
  },
}[lang];

const difficultyLabels: Record<string, string> =
  lang === 'en'
    ? { facile: 'Easy', modere: 'Moderate', difficile: 'Hard' }
    : { facile: 'Facile', modere: 'Modéré', difficile: 'Difficile' };

const difficultyClasses: Record<string, string> = {
  facile: 'bg-green-50 text-green-700',
  modere: 'bg-yellow-50 text-yellow-700',
  difficile: 'bg-red-50 text-red-700',
};
---

<BaseLayout
  title={`${data.title} — ${lang === 'en' ? 'Rodrigues Notebook' : 'Carnet de Rodrigues'}`}
  description={data.summary}
  lang={lang}
  homeUrl={blogHome}
  langSwitch={langSwitch}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-20">
    <div class="max-w-5xl mx-auto">
      <nav class="mb-8">
        <a href={blogHome} class="inline-flex items-center gap-1.5 text-sm text-blue-600 hover:text-blue-700 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          {backLabel}
        </a>
      </nav>

      <header class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-wider text-blue-600 mb-3">
          {categoryLabels[data.category]}
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-5 leading-tight">
          {data.title}
        </h1>
        <p class="text-xl text-gray-500 leading-relaxed">{data.summary}</p>

        <div class="flex flex-wrap gap-2 mt-6">
          {data.duration && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700">
              {data.duration}
            </span>
          )}
          {data.difficulty && (
            <span class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold ${difficultyClasses[data.difficulty]}`}>
              {difficultyLabels[data.difficulty]}
            </span>
          )}
          {data.guideRequired && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700 border border-blue-200">
              Guide requis
            </span>
          )}
          {data.zone && (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700">
              {data.zone}
            </span>
          )}
          {(data.tags ?? []).map((tag) => (
            <a
              href={`${blogHome}#tag=${encodeURIComponent(tag)}`}
              class="inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 hover:bg-blue-100 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </header>

      <figure class="mb-10">
        <img
          src={cover}
          alt={data.title}
          loading="eager"
          class="w-full aspect-[16/9] object-cover rounded-2xl shadow-sm"
        />
      </figure>

      <div class="prose-article">
        <slot />
      </div>

      <WhereToStay articleZone={data.zone} lang={lang} />
    </div>
  </article>
</BaseLayout>
