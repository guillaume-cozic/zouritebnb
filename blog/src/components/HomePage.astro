---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { articleHref, homeHref, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const all = await getCollection('articles');
const articles = all.filter((a) => a.data.lang === lang);
articles.sort((a, b) => a.data.order - b.data.order);

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const blogHome = homeHref(baseUrl, lang);

// Language switcher on the home: point to the other localized home.
const otherLang: Lang = lang === 'en' ? 'fr' : 'en';
const langSwitch = { href: homeHref(baseUrl, otherLang), lang: otherLang };

const categoryOrder = [
  'reserves-et-parcs',
  'points-de-vue',
  'randonnees',
  'sorties-en-mer',
  'sites-naturels',
  'patrimoine',
  'itineraires',
] as const;

const categoryLabels: Record<string, string> = ({
  fr: {
    'reserves-et-parcs': 'Réserves & parcs',
    'points-de-vue': 'Points de vue',
    'randonnees': 'Randonnées',
    'sorties-en-mer': 'Sorties en mer',
    'sites-naturels': 'Sites naturels',
    'patrimoine': 'Patrimoine',
    'itineraires': 'Itinéraires',
  },
  en: {
    'reserves-et-parcs': 'Reserves & parks',
    'points-de-vue': 'Viewpoints',
    'randonnees': 'Hikes',
    'sorties-en-mer': 'Sea trips',
    'sites-naturels': 'Natural sites',
    'patrimoine': 'Heritage',
    'itineraires': 'Itineraries',
  },
} as const)[lang];

const difficultyClasses: Record<string, string> = {
  facile: 'bg-green-50 text-green-700',
  modere: 'bg-yellow-50 text-yellow-700',
  difficile: 'bg-red-50 text-red-700',
};

const difficultyLabels: Record<string, string> =
  lang === 'en'
    ? { facile: 'Easy', modere: 'Moderate', difficile: 'Hard' }
    : { facile: 'Facile', modere: 'Modéré', difficile: 'Difficile' };

const grouped = categoryOrder
  .map((cat) => ({
    category: cat,
    items: articles.filter((a) => a.data.category === cat),
  }))
  .filter((g) => g.items.length > 0);

const allTags = Array.from(
  new Set(articles.flatMap((a) => a.data.tags ?? [])),
).sort((a, b) => a.localeCompare(b, lang));

const t = {
  fr: {
    pageTitle: 'Carnet de Rodrigues — Activités, balades et sorties',
    pageDescription:
      'Le guide pratique pour découvrir Rodrigues : réserves naturelles, randonnées côtières, sorties en mer et sites incontournables.',
    kicker: 'Le carnet',
    heroTitle: 'Carnet de Rodrigues',
    heroSubtitle:
      "Balades, sorties en mer, réserves naturelles : tout pour profiter de votre séjour sur l'île.",
    filtersKicker: 'Recherche & filtres',
    filtersTitle: 'Trouver un article',
    searchPlaceholder: 'Rechercher un mot dans les articles…',
    all: 'Tout',
    empty: 'Aucun article ne correspond à ce filtre.',
    guideRequired: 'Guide requis',
    articleSingular: 'article',
    articlePlural: 'articles',
  },
  en: {
    pageTitle: 'Rodrigues Notebook — Activities, walks and trips',
    pageDescription:
      'The practical guide to discover Rodrigues: nature reserves, coastal hikes, sea trips and must-see sites.',
    kicker: 'The notebook',
    heroTitle: 'Rodrigues Notebook',
    heroSubtitle:
      'Walks, sea trips, nature reserves: everything you need to make the most of your stay on the island.',
    filtersKicker: 'Search & filters',
    filtersTitle: 'Find an article',
    searchPlaceholder: 'Search a word across the articles…',
    all: 'All',
    empty: 'No article matches this filter.',
    guideRequired: 'Guide required',
    articleSingular: 'article',
    articlePlural: 'articles',
  },
}[lang];

const plural = (n: number) => (n > 1 ? t.articlePlural : t.articleSingular);

const articlesUrl = lang === 'en'
  ? `${baseUrl}articles.en.json`
  : `${baseUrl}articles.json`;

const heroSlides = [
  'https://images.unsplash.com/photo-1559128010-7c1ad6e1b6a5?auto=format&fit=crop&q=80&w=2000',
  'https://images.unsplash.com/photo-1506953823976-52e1fdc0149a?auto=format&fit=crop&q=80&w=2000',
  'https://images.unsplash.com/photo-1505881502353-a1986add3762?auto=format&fit=crop&q=80&w=2000',
  'https://images.unsplash.com/photo-1537956965359-7573183d1f57?auto=format&fit=crop&q=80&w=2000',
];
---

<BaseLayout
  title={t.pageTitle}
  description={t.pageDescription}
  lang={lang}
  homeUrl={blogHome}
  langSwitch={langSwitch}
>
  <div class="relative">
    <div class="relative h-[500px] w-full overflow-hidden">
      {heroSlides.map((src, i) => (
        <img
          src={src}
          alt=""
          data-hero-slide
          class={`absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 ease-in-out ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      ))}
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-black/20"></div>

      <div class="relative h-full flex flex-col items-center justify-center px-4 pb-16 pt-20">
        <p class="text-xs sm:text-sm font-semibold uppercase tracking-wider text-white/80 mb-3">
          {t.kicker}
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 text-center tracking-tight">
          {t.heroTitle}
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto text-center font-light">
          {t.heroSubtitle}
        </p>
      </div>

      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-2">
        {heroSlides.map((_, i) => (
          <button
            type="button"
            data-hero-dot
            aria-label={`Photo ${i + 1}`}
            class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? 'w-6 bg-white' : 'w-2 bg-white/50 hover:bg-white/70'}`}
          ></button>
        ))}
      </div>
    </div>
  </div>

  <div class="bg-gray-50/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20">
      <div class="mb-12">
        <div class="flex items-end justify-between mb-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-blue-600 mb-2">{t.filtersKicker}</p>
            <h2 class="text-2xl font-bold text-gray-900">{t.filtersTitle}</h2>
          </div>
          <p data-filter-count class="text-sm text-gray-500">{articles.length} {plural(articles.length)}</p>
        </div>

        <div class="relative mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.34-4.34" />
          </svg>
          <input
            type="search"
            data-search-input
            placeholder={t.searchPlaceholder}
            autocomplete="off"
            class="w-full h-12 rounded-xl border border-gray-200 bg-white pl-12 pr-4 text-sm placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-400 transition-all"
          />
        </div>

        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            data-tag-filter="__all__"
            class="px-4 py-2 rounded-full text-sm font-semibold border transition-colors bg-blue-600 text-white border-blue-600"
          >
            {t.all}
          </button>
          {allTags.map((tag) => (
            <button
              type="button"
              data-tag-filter={tag}
              class="px-4 py-2 rounded-full text-sm font-medium border transition-colors bg-white text-gray-700 border-gray-200 hover:border-blue-400"
            >
              {tag}
            </button>
          ))}
        </div>
      </div>

      <p
        data-empty-state
        class="hidden text-center text-gray-500 py-16"
      >
        {t.empty}
      </p>

      <div class="space-y-16">
        {grouped.map(({ category, items }) => (
          <section data-category-section={category} id={`cat-${category}`} class="scroll-mt-20">
            <div class="flex justify-between items-end mb-10">
              <div>
                <h2 class="text-3xl font-bold text-gray-900">{categoryLabels[category]}</h2>
                <p
                  data-category-count
                  data-total={items.length}
                  class="text-gray-500 mt-2"
                >{items.length} {plural(items.length)}</p>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {items.map((article) => (
                <a
                  href={articleHref(baseUrl, article)}
                  data-article-card
                  data-slug={article.slug}
                  data-tags={(article.data.tags ?? []).join('|')}
                  class="group flex flex-col rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1 transition-all overflow-hidden"
                >
                  <div class="aspect-video w-full overflow-hidden bg-gray-100 relative">
                    <img
                      src={article.data.cover ?? `https://picsum.photos/seed/${article.slug.replace(/^en\//, '')}/800/450`}
                      alt={article.data.title}
                      loading="lazy"
                      class="absolute inset-0 h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent pointer-events-none"></div>
                  </div>
                  <div class="p-5 flex-1 flex flex-col">
                    <p class="text-xs font-semibold uppercase tracking-wider text-blue-600 mb-2">
                      {categoryLabels[article.data.category]}
                    </p>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors leading-snug">
                      {article.data.title}
                    </h3>
                    <p class="text-sm text-gray-500 leading-relaxed mb-4 flex-1">{article.data.summary}</p>

                    <div class="flex flex-wrap gap-1.5 pt-4 border-t border-gray-100">
                      {(article.data.tags ?? []).map((tag) => (
                        <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
                          {tag}
                        </span>
                      ))}
                      {article.data.duration && (
                        <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-700">
                          {article.data.duration}
                        </span>
                      )}
                      {article.data.difficulty && (
                        <span class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold ${difficultyClasses[article.data.difficulty]}`}>
                          {difficultyLabels[article.data.difficulty]}
                        </span>
                      )}
                      {article.data.guideRequired && (
                        <span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700 border border-blue-200">
                          {t.guideRequired}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ ARTICLES_URL: articlesUrl }}>
  /* Hero slider */
  const slides = Array.from(document.querySelectorAll('[data-hero-slide]'));
  const dots = Array.from(document.querySelectorAll('[data-hero-dot]'));
  let current = 0;
  let timer;

  const setActive = (idx) => {
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === idx);
      slide.classList.toggle('opacity-0', i !== idx);
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('w-6', i === idx);
      dot.classList.toggle('bg-white', i === idx);
      dot.classList.toggle('w-2', i !== idx);
      dot.classList.toggle('bg-white/50', i !== idx);
      dot.classList.toggle('hover:bg-white/70', i !== idx);
    });
    current = idx;
  };

  const startAutoplay = () => {
    timer = window.setInterval(() => setActive((current + 1) % slides.length), 5000);
  };

  dots.forEach((dot, i) =>
    dot.addEventListener('click', () => {
      if (timer) window.clearInterval(timer);
      setActive(i);
      startAutoplay();
    }),
  );

  if (slides.length > 1) startAutoplay();

  /* Tag + fulltext filter */
  const filterButtons = Array.from(document.querySelectorAll('[data-tag-filter]'));
  const cards = Array.from(document.querySelectorAll('[data-article-card]'));
  const sections = Array.from(document.querySelectorAll('[data-category-section]'));
  const totalCounter = document.querySelector('[data-filter-count]');
  const emptyState = document.querySelector('[data-empty-state]');
  const searchInput = document.querySelector('[data-search-input]');

  const articleWord = totalCounter ? totalCounter.textContent.replace(/^\d+\s*/, '') : 'articles';

  const normalize = (s) =>
    s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase();

  let activeTag = '__all__';
  let searchQuery = '';
  let indexBySlug = null;

  const matchesSearch = (slug, query) => {
    if (!query) return true;
    if (!indexBySlug) return true;
    const entry = indexBySlug.get(slug);
    if (!entry) return true;
    const haystack = normalize(`${entry.title} ${entry.summary} ${entry.tags.join(' ')} ${entry.body}`);
    return query.split(/\s+/).filter(Boolean).every((token) => haystack.includes(token));
  };

  const applyFilters = () => {
    filterButtons.forEach((btn) => {
      const active = btn.dataset.tagFilter === activeTag;
      btn.classList.toggle('bg-blue-600', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('border-blue-600', active);
      btn.classList.toggle('font-semibold', active);
      btn.classList.toggle('bg-white', !active);
      btn.classList.toggle('text-gray-700', !active);
      btn.classList.toggle('border-gray-200', !active);
      btn.classList.toggle('font-medium', !active);
      btn.classList.toggle('hover:border-blue-400', !active);
    });

    const normalizedQuery = normalize(searchQuery.trim());

    let visibleTotal = 0;
    cards.forEach((card) => {
      const tags = (card.dataset.tags || '').split('|').filter(Boolean);
      const slug = card.dataset.slug || '';
      const tagOk = activeTag === '__all__' || tags.includes(activeTag);
      const searchOk = matchesSearch(slug, normalizedQuery);
      const visible = tagOk && searchOk;
      card.classList.toggle('hidden', !visible);
      if (visible) visibleTotal += 1;
    });

    sections.forEach((section) => {
      const count = section.querySelectorAll('[data-article-card]:not(.hidden)').length;
      section.classList.toggle('hidden', count === 0);
      const counter = section.querySelector('[data-category-count]');
      if (counter) counter.textContent = `${count} ${articleWord}`;
    });

    if (totalCounter) {
      totalCounter.textContent = `${visibleTotal} ${articleWord}`;
    }
    if (emptyState) {
      emptyState.classList.toggle('hidden', visibleTotal > 0);
    }

    if (activeTag === '__all__' && !searchQuery) {
      history.replaceState(null, '', window.location.pathname);
    } else if (activeTag !== '__all__' && !searchQuery) {
      history.replaceState(null, '', `#tag=${encodeURIComponent(activeTag)}`);
    }
  };

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeTag = btn.dataset.tagFilter || '__all__';
      applyFilters();
    });
  });

  if (searchInput) {
    let debounce;
    searchInput.addEventListener('input', () => {
      if (debounce) window.clearTimeout(debounce);
      debounce = window.setTimeout(() => {
        searchQuery = searchInput.value;
        applyFilters();
      }, 120);
    });
  }

  fetch(ARTICLES_URL)
    .then((r) => (r.ok ? r.json() : []))
    .then((entries) => {
      indexBySlug = new Map(entries.map((e) => [e.slug, { ...e, body: normalize(e.body) }]));
      if (searchInput && searchInput.value) {
        searchQuery = searchInput.value;
        applyFilters();
      }
    })
    .catch(() => {
      /* fallback: search disabled, tag filter still works */
    });

  const hashMatch = window.location.hash.match(/^#tag=(.+)$/);
  if (hashMatch) {
    const tag = decodeURIComponent(hashMatch[1]);
    if (filterButtons.some((b) => b.dataset.tagFilter === tag)) {
      activeTag = tag;
      applyFilters();
    }
  }
</script>
