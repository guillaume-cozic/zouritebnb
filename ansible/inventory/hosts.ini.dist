# Copy this file to hosts.ini and fill in your VPS connection details.
#   cp inventory/hosts.ini.dist inventory/hosts.ini
#
# hosts.ini is gitignored: it contains the server address and SSH user.

[production]
vps ansible_host=203.0.113.10 ansible_user=deploy ansible_port=22

[production:vars]
# Path to the SSH private key able to log into the server.
ansible_ssh_private_key_file = ~/.ssh/id_ed25519
