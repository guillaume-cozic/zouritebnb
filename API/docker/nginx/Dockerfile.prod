# syntax=docker/dockerfile:1.7

# L'image PHP fournit /var/www/html/public (avec bundles).
# Le tag est injecté par le workflow CI (image PHP fraîchement construite).
ARG PHP_IMAGE
FROM ${PHP_IMAGE} AS php_assets

FROM nginx:1.27-alpine

COPY docker/nginx/prod.conf /etc/nginx/conf.d/default.conf

COPY --from=php_assets /var/www/html/public /var/www/html/public

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
