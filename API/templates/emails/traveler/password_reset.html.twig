{% extends 'emails/base.html.twig' %}

{% block heading %}Réinitialisation du mot de passe 🔑{% endblock %}

{% block content %}
  {% set p = 'margin:0 0 16px;line-height:1.6;color:#374151;' %}
  <p style="{{ p }}">Bonjour {{ greetingName }},</p>
  <p style="{{ p }}">Vous avez demandé à réinitialiser le mot de passe de votre compte <strong>BnB Rodrigues</strong>. Cliquez sur le bouton ci-dessous pour en choisir un nouveau.</p>
  <p style="margin:24px 0;">
    <a href="{{ resetUrl }}" style="display:inline-block;background:#1d4ed8;color:#ffffff;text-decoration:none;font-weight:bold;padding:14px 28px;border-radius:10px;">Réinitialiser mon mot de passe</a>
  </p>
  <p style="{{ p }}">Ce lien est valable <strong>une heure</strong>. Si le bouton ne fonctionne pas, copiez-collez cette adresse dans votre navigateur :</p>
  <p style="margin:0 0 16px;line-height:1.6;color:#6b7280;word-break:break-all;">{{ resetUrl }}</p>
  <p style="{{ p }}">Si vous n'êtes pas à l'origine de cette demande, ignorez simplement cet email : votre mot de passe actuel reste inchangé.</p>
{% endblock %}
