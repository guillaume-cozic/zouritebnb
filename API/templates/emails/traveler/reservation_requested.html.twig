{% extends 'emails/base.html.twig' %}

{% block heading %}Demande envoyée{% endblock %}

{% block content %}
  {% set p = 'margin:0 0 16px;line-height:1.6;color:#374151;' %}
  <p style="{{ p }}">Bonjour {{ greetingName }},</p>
  <p style="{{ p }}">Votre <strong>demande de réservation</strong> pour « {{ accommodationTitle }} »{% if city %}, {{ city }}{% endif %} a bien été transmise à votre hôte. 🙌</p>
  <p style="{{ p }}">📅 Du <strong>{{ checkIn|date('d/m/Y') }}</strong> au <strong>{{ checkOut|date('d/m/Y') }}</strong> ({{ nights }} nuit{{ nights > 1 ? 's' }}).</p>
  <p style="{{ p }}">Votre hôte dispose de <strong>24 heures</strong> pour répondre. <strong>Aucun montant ne sera prélevé tant que votre hôte n'a pas accepté</strong> ; à défaut, l'autorisation de paiement est automatiquement libérée.</p>
{% endblock %}
