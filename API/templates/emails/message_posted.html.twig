{% extends 'emails/base.html.twig' %}

{% block heading %}Nouveau message ✉️{% endblock %}

{% block content %}
  {% set p = 'margin:0 0 16px;line-height:1.6;color:#374151;' %}
  <p style="{{ p }}">Bonjour {{ greetingName }},</p>
  <p style="{{ p }}">Vous avez reçu un nouveau message de <strong>{{ senderName }}</strong>{% if accommodationTitle %} à propos de « {{ accommodationTitle }} »{% endif %}.</p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 16px;">
    <tr><td style="border-left:3px solid #1d4ed8;background:#f9fafb;padding:12px 16px;color:#374151;line-height:1.6;white-space:pre-line;">{{ messageBody }}</td></tr>
  </table>
  <p style="{{ p }}">Connectez-vous à votre messagerie BnB Rodrigues pour répondre.</p>
{% endblock %}
