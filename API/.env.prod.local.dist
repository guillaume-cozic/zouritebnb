# Template for production env vars. Copy to .env.prod.local on the VPS and fill in real values.
# .env.*.local files are gitignored.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me

# MySQL (consommé par l'image mysql:8.4 ET par l'app via DATABASE_URL)
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=change-me

# Symfony / Doctrine
DATABASE_URL=mysql://app:change-me@mysql:3306/app?serverVersion=8.4
DEFAULT_URI=https://api.zouritebnb.com
# Production: allow HTTPS origins only (no plaintext http).
# Front (www) + back-office admin (adm) are the only browser origins.
CORS_ALLOW_ORIGIN=^https://(www|adm)\.zouritebnb\.com$

# Derrière Cloudflare : sans cette liste, getClientIp() renvoie l'IP du proxy
# (conteneur nginx / edge Cloudflare) et les rate limiters "par IP" (login,
# register…) seraient partagés entre tous les visiteurs.
# `private_ranges` couvre la chaîne locale (Apache → conteneur nginx) ; les
# plages Cloudflare permettent de remonter jusqu'à l'IP réelle du client.
# Plages à jour : https://www.cloudflare.com/ips/ (vérifier ~1×/an).
SYMFONY_TRUSTED_PROXIES=private_ranges,173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22,2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32

# URL publique du front, sans slash final (liens des emails transactionnels
# + base des URLs du sitemap /sitemap.xml).
FRONTEND_URL=https://www.zouritebnb.com

# Messenger
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Stripe
STRIPE_SECRET_KEY=sk_live_change_me
STRIPE_PUBLISHABLE_KEY=pk_live_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_CURRENCY=eur
