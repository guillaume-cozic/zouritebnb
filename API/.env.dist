# Template d'environnement: copié en .env par le CI et le Dockerfile prod
# avant le boot Symfony. Les vraies valeurs sont injectées en prod via .env.prod.local
# (env_file: dans docker-compose.prod.yml).
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://app:secret@mysql:3306/app?serverVersion=8.4"
###< doctrine/doctrine-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> stripe ###
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=eur
###< stripe ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=1567add6f6f63c9896fff2cd6eb680a5a7d9c3c45d904e7b9d07b6768a4b9e0a
###< lexik/jwt-authentication-bundle ###

###> app/social-auth ###
# OAuth credentials for social login. Leave empty to disable a provider — the
# matching button is then hidden on the front and the API rejects its tokens.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
###< app/social-auth ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> app/notification ###
# Sender identity for transactional emails (outbox).
MAILER_FROM_EMAIL=bonjour@bnb-rodrigues.com
MAILER_FROM_NAME="BnB Rodrigues"
# Public base URL of the front app, used to build links in transactional emails
# (email verification, password reset). No trailing slash.
FRONTEND_URL=http://localhost:3000
###< app/notification ###
